# Vayu configuration — copy to .env and fill in what you have. Everything is optional;
# Vayu runs fully offline on its bundled dataset + local rule-based assistant if empty.

# --- AI backend (provider-agnostic) ---
# If a Gemini key is present, the "Ask Vayu" assistant uses Gemini for natural-language
# reasoning. Otherwise it falls back to OpenAI (if set), then to a local deterministic
# assistant that composes answers from the analytics engine.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini

# --- Live data (optional) ---
# OpenAQ v3 API key enables pulling live real-world measurements to enrich the dataset.
# Get a free key at https://explore.openaq.org/. Without it, Vayu uses its bundled data.
OPENAQ_API_KEY=

# --- Server ---
VAYU_HOST=0.0.0.0
VAYU_PORT=8095
